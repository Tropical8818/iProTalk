# iProTalk Environment Configuration
# Copy this file to .env and fill in values

# REQUIRED: JWT signing secret (generate a strong random string)
SECRET_KEY=your-secure-random-string-here

# Database
DATABASE_URL=sqlite:///app/data/iprotalk.db?mode=rwc
MSG_DB_PATH=msg_db

# Logging
RUST_LOG=poem=info,ipro_talk=info

# Frontend port (Docker)
FRONTEND_PORT=8080

# Optional: OAuth2 (future)
# OAUTH2_CLIENT_ID=
# OAUTH2_CLIENT_SECRET=
# OAUTH2_REDIRECT_URI=
