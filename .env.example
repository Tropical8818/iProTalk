# iProTalk Environment Configuration
# Copy this file to .env and fill in values

# REQUIRED: JWT signing secret (generate a strong random string)
SECRET_KEY=your-secure-random-string-here

# Database
DATABASE_URL=sqlite:///app/data/iprotalk.db?mode=rwc
MSG_DB_PATH=msg_db

# Logging
RUST_LOG=poem=info,ipro_talk=info

# Frontend port (Docker)
FRONTEND_PORT=8080

# GitHub OAuth2
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/oauth2/github/callback

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth2/google/callback
